 * モヤット — 設定ファイル
 * リフレーミング授業用Webツール（小5向け）のバックエンド設定。
 *
 * 設計の核:
 *   「事実は変えずに、受け取り方を複数持つ」。1つ目の見方でメーター半分、
 *   2つ目の有効な見方でスッキリ。安易な受容はしないが、問い返しはやさしく短く。
 */

// ===== Gemini 設定 =====
// APIキーはコードに書かない。先生用ダッシュボードの「設定」から、または
//   GASエディタの「プロジェクトの設定 > スクリプト プロパティ」で GEMINI_API_KEY を登録する。
var MODEL = 'gemini-3.1-flash-lite';   // Gemini 3.1 Flash-Lite（GA・低コスト/低レイテンシ。約$0.25/$1.50 per 1M）。thinkingLevel対応。'gemini-3.5-flash'/'gemini-2.5-flash' 等にも変更可。
var TEMPERATURE = 0.6;            // やさしく自然な揺らぎ。判定を安定させるため少し低め。
// 思考設定はモデル世代で形式が違う（Code.gs の thinkingConfig_ が MODEL を見て自動で使い分ける）:
//   Gemini 3.x → THINKING_LEVEL（'minimal' | 'low' | 'medium' | 'high'）
//   Gemini 2.x → THINKING_BUDGET（数値。0 で思考オフ）
var THINKING_LEVEL = 'low';       // 3.x用。速く軽快。判定の質を上げたいなら 'medium' に。
var THINKING_BUDGET = 0;          // 2.x用（MODEL を 2.x 系に戻したときに使われる）。

// ===== クリア判定のきびしさ =====
// 現在は全設定で「有効な見方2つでクリア」を基本にする。
var CLEAR_STRICTNESS = 'strict';

function getApiKey_() {
  var key = PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
  if (!key) {
    throw new Error('GEMINI_API_KEY が未設定です。先生用ダッシュボードの「設定」から登録してください。');
  }
  return key;
}

/** APIキーが設定済みかだけ確認（例外を投げない）。 */
function hasApiKey_() {
  return !!PropertiesService.getScriptProperties().getProperty('GEMINI_API_KEY');
}

