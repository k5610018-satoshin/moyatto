function enrichTroubles_(list) {
  var result = [];
  for (var i = 0; i < (list || []).length; i++) {
    var src = list[i] || {};
    var t = {};
    for (var k in src) t[k] = src[k];
    var dirs = TROUBLE_REFRAME_DIRECTIONS[t.id];
    if (dirs && dirs.length) t.reframes = dirs.slice();
    result.push(t);
  }
  return result;
}

function auditDefaultReframes_() {
  var enriched = enrichTroubles_(DEFAULT_TROUBLES);
  var missing = [];
  for (var i = 0; i < enriched.length; i++) {
    var t = enriched[i];
    if (!t.reframes || t.reframes.length < 3) missing.push(t.id + ':' + (t.reframes ? t.reframes.length : 0));
  }
  return missing;
}

/** 有効な悩みプールを返す（SHEET_ID があればシート優先、失敗時はデフォルトに退避。先生承認の追加悩みを末尾に合流）。 */
function getTroubles_() {
  var base = null;
  if (SHEET_ID) {
    try {
      var fromSheet = loadTroublesFromSheet_();
      if (fromSheet && fromSheet.length) base = fromSheet;
    } catch (e) {
      // シート読み込み失敗時はデフォルトにフォールバック（授業を止めない）
    }
  }
  if (!base) base = DEFAULT_TROUBLES;
  base = enrichTroubles_(base);
  // 参加者が提案し先生が承認した悩みを末尾に合流（Session.gs。無ければ何もしない）
  try {
    var extra = getApprovedExtraTroubles_();
    if (extra && extra.length) return base.concat(enrichTroubles_(extra));
  } catch (e) { /* 失敗時は基本プールのみ */ }
  return base;
}

function findTrouble_(id) {
  var pool = getTroubles_();
  for (var i = 0; i < pool.length; i++) {
    if (pool[i].id === id) return pool[i];
  }
  return null;
}

function targetReframesText_(t) {
  if (!t || !t.reframes || !t.reframes.length) return '';
  return [
    '【先生が大切にしたいリフレーミングの方向（内部基準）】',
    '- ' + t.reframes.join('\n- '),
    '※これは判定の参考です。児童へのヒントや返事に、そのまま答えとして丸写ししない。'
  ].join('\n');
}

