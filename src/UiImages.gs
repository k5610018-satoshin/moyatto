/** モヤット UI画像アセット（生成画像を軽量化したData URI）。 */
var UI_ASSETS = {
  classroom: 'data:image/jpeg;base64,',
  avatarTalk: 'data:image/webp;base64,',
  avatarWorried: 'data:image/webp;base64,',
  avatarThinking: 'data:image/webp;base64,',
  avatarAha: 'data:image/webp;base64,',
  avatarClear: 'data:image/webp;base64,'
};

function getUiImages_() {
  return UI_ASSETS || {};
}

function getAvatars_() {
  var base = {};
  try {
    if (typeof AVATARS !== 'undefined' && AVATARS) {
      for (var k in AVATARS) base[k] = AVATARS[k];
    }
  } catch (e) {}
  var a = getUiImages_();
  var generated = {
    talk: a.avatarTalk,
    trouble: a.avatarWorried,
    sad: a.avatarWorried,
    worried: a.avatarWorried,
    anxious: a.avatarWorried,
    thinking: a.avatarThinking,
    aha: a.avatarAha,
    happy: a.avatarClear,
    confident: a.avatarAha,
    relieved: a.avatarClear,
    motivated: a.avatarClear,
    clear: a.avatarClear
  };
  for (var key in generated) {
    if (generated[key]) base[key] = generated[key];
  }
  return base;
}
